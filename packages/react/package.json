{
  "name": "@expertrees/react",
  "version": "1.0.0",
  "description": "React hook and component for @expertrees/core",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/0xMack/expertrees.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "knowledge-graph",
    "skill-tree",
    "react",
    "visualization"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@expertrees/core": "*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.4.0"
  }
}
